<Window x:Class="ColumnPadStudio.Controls.WorkflowBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workflow Builder"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="#FFB7B7B7"
                BorderThickness="1"
                Padding="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="New" Width="62" Margin="0,0,6,0" Click="NewWorkflow_Click"/>
                        <Button Content="Save"
                                Width="62"
                                Margin="0,0,6,0"
                                Click="SaveWorkflow_Click"
                                IsEnabled="{Binding HasSelectedWorkflow}"/>
                        <Button Content="Delete"
                                Width="62"
                                Click="DeleteWorkflow_Click"
                                IsEnabled="{Binding HasSelectedWorkflow}"/>
                    </StackPanel>

                    <Border Margin="0,8,0,8" Height="1" Background="#22000000"/>

                    <TextBlock Text="Built-in templates:" FontWeight="SemiBold"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox ItemsSource="{Binding Templates}"
                                  SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"/>
                        <Button Grid.Column="1"
                                Content="Use"
                                Width="56"
                                Margin="6,0,0,0"
                                Click="UseTemplate_Click"
                                IsEnabled="{Binding HasSelectedTemplate}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Import JSON"
                                Width="108"
                                Margin="0,0,6,0"
                                Click="ImportWorkflowJson_Click"/>
                        <Button Content="Export JSON"
                                Width="108"
                                Click="ExportWorkflowJson_Click"
                                IsEnabled="{Binding HasSelectedWorkflow}"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Margin="0,8,0,0"
                           Foreground="#FF5F5F5F"
                           Text="{Binding SelectedWorkflowFileLabel}"/>

                <ListBox Margin="0,8,0,0"
                         ItemsSource="{Binding Workflows}"
                         SelectedItem="{Binding SelectedWorkflow, Mode=TwoWay}"
                         DisplayMemberPath="Name"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2" IsEnabled="{Binding HasSelectedWorkflow}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Name:"/>
                <TextBox Grid.Column="1"
                         Margin="0,0,12,0"
                         Text="{Binding SelectedWorkflow.Name, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Center" Text="Trigger:"/>
                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding TriggerTypes}"
                          SelectedItem="{Binding SelectedWorkflow.Trigger, Mode=TwoWay}"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Description:"/>
                <TextBox Grid.Row="1"
                         Margin="0,4,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding SelectedWorkflow.Description, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Category:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="220"
                             Text="{Binding SelectedWorkflow.Category, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#FFB7B7B7"
                        BorderThickness="1"
                        Padding="8">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <Button Content="+ Step"
                                    Width="62"
                                    Margin="0,0,6,0"
                                    Click="AddStep_Click"
                                    IsEnabled="{Binding HasSelectedWorkflow}"/>
                            <Button Content="- Step"
                                    Width="62"
                                    Margin="0,0,6,0"
                                    Click="RemoveStep_Click"
                                    IsEnabled="{Binding HasSelectedStep}"/>
                            <Button Content="Up"
                                    Width="48"
                                    Margin="0,0,6,0"
                                    Click="MoveStepUp_Click"
                                    IsEnabled="{Binding HasSelectedStep}"/>
                            <Button Content="Down"
                                    Width="52"
                                    Click="MoveStepDown_Click"
                                    IsEnabled="{Binding HasSelectedStep}"/>
                        </StackPanel>

                        <ListBox Margin="0,8,0,0"
                                 ItemsSource="{Binding SelectedWorkflow.Steps}"
                                 SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                                 DisplayMemberPath="Summary"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2"
                        BorderBrush="#FFB7B7B7"
                        BorderThickness="1"
                        Padding="10"
                        IsEnabled="{Binding HasSelectedStep}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Kind:"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding StepKinds}"
                                  SelectedItem="{Binding SelectedStep.Kind, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="1" Margin="0,10,8,0" VerticalAlignment="Center" Text="Argument:"/>
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,10,0,0"
                                 Text="{Binding SelectedStep.Argument, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="2" Margin="0,10,8,0" VerticalAlignment="Top" Text="Notes:"/>
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,10,0,0"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding SelectedStep.Notes, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="3"
                    Margin="0,10,0,0"
                    BorderBrush="#FFB7B7B7"
                    BorderThickness="1"
                    Padding="8,6">
                <TextBlock Text="{Binding StatusText}"/>
            </Border>
        </Grid>
    </Grid>
</Window>

