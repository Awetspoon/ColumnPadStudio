<Window x:Class="ColumnPadStudio.App.Views.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find"
        Width="420"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="Find text"
                   VerticalAlignment="Center"
                   Margin="0,0,12,12"
                   Foreground="{DynamicResource ForegroundBrush}" />
        <TextBox x:Name="FindTextBox"
                 Grid.Column="1"
                 Margin="0,0,0,12"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock x:Name="ReplaceLabel"
                   Grid.Row="1"
                   Text="Replace with"
                   VerticalAlignment="Center"
                   Margin="0,0,12,12"
                   Foreground="{DynamicResource ForegroundBrush}" />
        <TextBox x:Name="ReplaceTextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,0,0,12"
                 Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}" />

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrushStrong}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <TextBlock x:Name="HintTextBlock"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ForegroundMutedBrush}"
                       FontSize="12"
                       Text="Find searches the active workspace across all columns. Replace all updates every match in the current workspace." />
        </Border>

        <StackPanel Grid.Row="3"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Width="96"
                    Margin="0,0,10,0"
                    Content="OK"
                    IsDefault="True"
                    Click="OnAcceptClick" />
            <Button Width="96"
                    Content="Cancel"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
